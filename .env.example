# ================================================================
# ЗМІННІ СЕРЕДОВИЩА ДЛЯ VERCEL
# ================================================================
# Додай кожну змінну в: Vercel → Settings → Environment Variables
# НЕ вставляй реальні значення в цей файл!

# ── Notion токен (ТІЛЬКИ це без VITE_) ───────────────────────
# Vercel Key:   NOTION_TOKEN
# Vercel Value: ntn_xxxxxxxxxxxxxxxx
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxx

# ── ID баз Notion (32 символи з URL) ─────────────────────────
# Як знайти: відкрий базу → URL → частина між / та ?
VITE_DB_SHIFTS=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_DB_STAFF=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_DB_ADVANCES=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_DB_BONUSES=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_DB_FIXED_STAFF=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_DB_DEBTS=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_DB_DEBT_PAYMENTS=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── НОВІ бази (треба створити в Notion) ───────────────────────
VITE_DB_SETTINGS=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_DB_LOGS=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Telegram ID власників (через кому) ───────────────────────
# Як дізнатись: напиши @userinfobot в Telegram
VITE_OWNER_IDS=123456789,987654321

# ================================================================
# НОВІ БАЗИ NOTION — ТРЕБА СТВОРИТИ
# ================================================================
#
# 1. База "Налаштування" — одна сторінка з полями:
#    - Назва (Title)
#    - Мін. днів для бонусів (Number) — default: 19
#    - Бонус за день 10+ год (Number) — default: 100
#    - Бонус за суботу (Number) — default: 300
#    - Днів для премії (Number) — default: 21
#    - Сума премії (Number) — default: 4000
#    - Годин для довгого дня (Number) — default: 10
#    - Потрібно довгих днів (Number) — default: 10
#    Створи одну сторінку з назвою "Налаштування" і заповни значення
#
# 2. База "Лог дій" — автоматично заповнюється системою:
#    - Дія (Title)
#    - ID (Number)
#    - ПІБ (Text)
#    - Деталі (Text)
#    - Дата (Date)
#
# ================================================================
# ПІДКЛЮЧЕННЯ ІНТЕГРАЦІЇ
# ================================================================
# Для КОЖНОЇ бази (включно з новими):
# 1. Відкрий базу в Notion
# 2. Натисни "..." вгорі справа
# 3. Connections → знайди свою інтеграцію → Connect
